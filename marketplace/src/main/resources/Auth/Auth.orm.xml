<?xml version = "1.0" encoding = "utf-8"?>
<!DOCTYPE hibernate-mapping PUBLIC
        "-//Hibernate/Hibernate Mapping DTD//EN"
        "http://www.hibernate.org/dtd/hibernate-mapping-3.0.dtd">

<hibernate-mapping>
    <class name = "com.marketplace.Auth.domain.User" table = "`Users`" entity-name="User_Auth">

        <meta attribute = "class-description">
            This class contains the employee detail.
        </meta>

        <id name = "id" type = "string" column = "id">
            <generator class="com.marketplace.Util.CustomGenerator"/>
        </id>

        <property name = "email" column = "email" type = "string" not-null="true"/>
        <property name= "name" column="name" type="string" not-null="true" />
        <property name="password" column="password" type="string" not-null="true" />
        <property name="isDeleted" column="is_deleted" type="boolean" />
        <property name="createdAt" column="created_at" type="LocalDateTime" not-null="false" />
        <property name="updatedTimes" column="updated_times" type="LocalDateTime" not-null="false" />

<!--        <set name="accountRoles" table="`Account_Roles`" lazy="true" fetch="select" cascade="persist">-->
<!--            <key>-->
<!--                <column name="account_id" not-null="true" />-->
<!--            </key>-->
<!--            <many-to-many entity-name="com.marketplace.Auth.domain.Role">-->
<!--                <column name="role_id" not-null="true"/>-->
<!--            </many-to-many>-->
<!--        </set>-->
        <set name = "accountRoles" cascade="persist" table="`Account_Roles`" lazy="true">
            <key column = "account_id"/>
            <many-to-many column = "role_id" class="com.marketplace.Auth.domain.Role"/>
        </set>

        </class>

    <class name = "com.marketplace.Auth.domain.Role" table = "`Roles`">
        <meta attribute = "class-description">
            This class contains the employee detail.
        </meta>

        <id name = "id" type = "string" column = "id">
            <generator class="com.marketplace.Util.CustomGenerator"/>
        </id>

        <property name="roleName" column="role_name" not-null="true">
            <type name="org.hibernate.type.EnumType">
                <param name="enumClass">com.marketplace.Auth.domain.Role$RoleEnum</param>
                <param name="useNamed">true</param>
            </type>
        </property>

        <set name = "users" inverse="true" table="`Account_Roles`" lazy="true">
            <key column = "role_id"/>
            <many-to-many column = "account_id" class="com.marketplace.Auth.domain.User" entity-name="User_Auth"/>
        </set>

<!--        <set name="users" table="`Account_Roles`" inverse="true">-->
