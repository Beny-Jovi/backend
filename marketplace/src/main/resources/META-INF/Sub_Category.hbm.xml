<?xml version = "1.0" encoding = "utf-8"?>
<!DOCTYPE hibernate-mapping PUBLIC
        "-//Hibernate/Hibernate Mapping DTD//EN"
        "http://www.hibernate.org/dtd/hibernate-mapping-3.0.dtd">

<hibernate-mapping>
    <class name="com.marketplace.Sub_Category_Management.domain.Category" table="`Categories`" entity-name="Category_Sub_Category_Management">
        <id name="id" type="string" column="id">
            <generator class="com.marketplace.Util.CustomGenerator" />
        </id>

        <property name="name" column="name" not-null="true" type="string" />
        <property name="createdAt" column="created_at" not-null="true" />
        <property name="isDeleted" column="is_deleted" />

        <set name="subCategories" cascade="all" lazy="true">
            <key column="category_id" />
            <one-to-many entity-name="Sub_Category_SubCategoryManagement" />
        </set>
    </class>

    <class name="com.marketplace.Sub_Category_Management.domain.SubCategory" table="`Sub_Categories`" entity-name="Sub_Category_SubCategoryManagement">
        <id name="id" type="string" column="id">
            <generator class="com.marketplace.Util.CustomGenerator"/>
        </id>

        <property name="subCategoryName" column="sub_category_name" length="80" not-null="true" type="string" />
        <property name="createdAt" column="created_at" not-null="true" type="LocalDateTime" />
        <property name="isDeleted" column="is_deleted" type="boolean" />

        <many-to-one name="category" column="category_id" entity-name="Category_Sub_Category_Management" not-null="true" />
    </class>
</hibernate-mapping>