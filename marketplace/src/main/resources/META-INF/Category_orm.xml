<?xml version="1.0" encoding="UTF-8"?>
<entity-mappings xmlns="http://xmlns.jcp.org/xml/ns/persistence/orm"
                 xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
                 xsi:schemaLocation="http://xmlns.jcp.org/xml/ns/persistence/orm
                                    http://xmlns.jcp.org/xml/ns/persistence/orm_2_2.xsd"
                 version="2.2">

    <description>ORM mapping for Category entity</description>
    <package>com.marketplace.CategoryManagement</package>

    <entity class="com.marketplace.CategoryManagement.domain.Category" name="Category_Management">
        <table name="Categories"/>
        <attributes>
            <id name="id">
                <generated-value generator="com.marketplace.Util.CustomGenerator"/>
            </id>
            <basic name="name">
                <column name="name" length="80" nullable="false"/>
            </basic>
            <basic name="createdAt">
                <column name="created_at" nullable="false" updatable="false"/>
            </basic>
            <basic name="isDeleted">
                <column name="is_deleted"/>
            </basic>
        </attributes>
    </entity>

</entity-mappings>