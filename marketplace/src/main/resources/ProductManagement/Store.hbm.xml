<?xml version = "1.0" encoding = "utf-8"?>
<!DOCTYPE hibernate-mapping PUBLIC
        "-//Hibernate/Hibernate Mapping DTD//EN"
        "http://www.hibernate.org/dtd/hibernate-mapping-3.0.dtd">

<hibernate-mapping>
    <class name = "com.marketplace.DiscProductManagement.Domain.Store" table = "`Stores`">

        <meta attribute = "class-description">
            This class contains the employee detail.
        </meta>

        <id name = "id" type = "string" column = "id">
            <generator class="com.marketplace.Util.CustomGenerator"/>
        </id>

        <set name = "products" cascade="all">
            <key column = "store_id"/>
            <one-to-many class="com.marketplace.DiscProductManagement.Domain.Product"/>
        </set>

        <property name = "name" column = "name" type = "string" not-null="true"/>
        <property name = "createdAt" column="created_at" type="timestamp" not-null="true" update="false" />
        <property name = "updatedTimes" column="updated_times" type="timestamp" not-null="true" />

    </class>
    <class name="com.marketplace.DiscProductManagement.Domain.Product" table="`Products`">
        <meta attribute = "class-description">
            This class contains the certificate records.
        </meta>
        <id name = "id" type = "string" column = "id">
            <generator class="com.marketplace.Util.CustomGenerator"/>
        </id>
        <property name = "orderMinimum" column = "order_minimum" type = "int" not-null="true"/>
        <property name = "createdAt" column = "created_at" type = "LocalDateTime" not-null="true"/>
        <many-to-one name="store" column="store_id" class="com.marketplace.DiscProductManagement.Domain.Store" not-null="true" />
    </class>
</hibernate-mapping>