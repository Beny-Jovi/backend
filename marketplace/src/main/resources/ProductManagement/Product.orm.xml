<?xml version = "1.0" encoding = "utf-8"?>
<!DOCTYPE hibernate-mapping PUBLIC
        "-//Hibernate/Hibernate Mapping DTD//EN"
        "http://www.hibernate.org/dtd/hibernate-mapping-3.0.dtd">

<hibernate-mapping>
    <class name = "com.marketplace.DiscProductManagement.Domain.Category" table = "`Categories`">

        <meta attribute = "class-description">
            This class contains the employee detail.
        </meta>

        <id name = "id" type = "string" column = "id">
            <generator class="com.marketplace.Util.CustomGenerator"/>
        </id>

        <set name = "subCategories" cascade="all">
            <key column = "category_id"/>
            <one-to-many class="com.marketplace.DiscProductManagement.Domain.SubCategory"/>
        </set>

        <!--        <property name = "name" column = "name" type = "string" not-null="true"/>-->
        <property name="name" column="name" not-null="true">
            <type name="org.hibernate.type.EnumType">
                <param name="enumClass">com.marketplace.DiscProductManagement.Domain.Category$CategoryEnum</param>
                <param name="useNamed">true</param>
            </type>
        </property>

    </class>
    <class name="com.marketplace.DiscProductManagement.Domain.SubCategory" table="`Sub_Categories`">
        <meta attribute = "class-description">
            This class contains the certificate records.
        </meta>
        <id name = "id" type = "string" column = "id">
            <generator class="com.marketplace.Util.CustomGenerator"/>
        </id>
        <set name = "products" cascade="all">
            <key column = "sub_category_id"/>
            <one-to-many class="com.marketplace.DiscProductManagement.Domain.Product" />
        </set>

        <many-to-one name="category" column="category_id" class="com.marketplace.DiscProductManagement.Domain.Category" not-null="true" />
        <!--        <property name = "name" column = "name" type = "string" not-null="true"/>-->
        <property name="name" column="name" not-null="true">
            <type name="org.hibernate.type.EnumType">
                <param name="enumClass">com.marketplace.DiscProductManagement.Domain.SubCategory$SubCategoryEnum</param>
                <param name="useNamed">true</param>
            </type>
        </property>
    </class>

    <class name = "com.marketplace.DiscProductManagement.Domain.Store" table = "`Stores`">

        <meta attribute = "class-description">
            This class contains the employee detail.
        </meta>

        <id name = "id" type = "string" column = "id">
            <generator class="com.marketplace.Util.CustomGenerator"/>
        </id>

        <set name = "products" cascade="all">
            <key column = "store_id"/>
            <one-to-many class="com.marketplace.DiscProductManagement.Domain.Product"/>
        </set>

        <property name = "name" column = "name" type = "string" not-null="true"/>
        <property name = "createdAt" column="created_at" type="timestamp" not-null="true" update="false" />
        <property name = "updatedTimes" column="updated_times" type="timestamp" not-null="true" />

    </class>

    <class name="com.marketplace.DiscProductManagement.Domain.Product" table="`Products`">
        <meta attribute = "class-description">
            This class contains the certificate records.
        </meta>
        <id name = "id" type = "string" column = "id">
            <generator class="com.marketplace.Util.CustomGenerator"/>
        </id>
        <property name = "orderMinimum" column = "order_minimum" type = "integer" not-null="true"/>
        <property name = "createdAt" column = "created_at" type = "LocalDateTime" not-null="true"/>
        <property name ="isDeleted" column="is_deleted" type="boolean" />
        <many-to-one name="subCategory" column="sub_category_id" class="com.marketplace.DiscProductManagement.Domain.SubCategory" not-null="true"/>
        <many-to-one name="store" column="store_id" class="com.marketplace.DiscProductManagement.Domain.Store" not-null="true" />
        <one-to-one name="productView" class="com.marketplace.DiscProductManagement.Domain.ProductView" cascade="all"  />
        <one-to-one name="Disc" class="com.marketplace.DiscProductManagement.Domain.Disc" cascade="all" />
    </class>

    <class name="com.marketplace.DiscProductManagement.Domain.ProductView" table="`Product_View`">
        <meta attribute = "class-description">
            This class contains the certificate records.
        </meta>
        <id name = "id" type = "string" column = "product_id">
            <generator class="foreign">
                <param name="property">product</param>
            </generator>
        </id>

        <property name = "numberOfView" column = "number_of_view" type = "int" not-null="true"/>
        <property name = "productRate" column = "product_rate" type = "int" not-null="true"/>
        <one-to-one name="product" class="com.marketplace.DiscProductManagement.Domain.Product" constrained="true" />

    </class>

    <class name="com.marketplace.DiscProductManagement.Domain.Disc" table="`Disc`">
        <meta attribute = "class-description">
            This class contains the certificate records.
        </meta>
        <id name = "id" type = "string" column = "product_id">
            <generator class="foreign">
                <param name="property">product</param>
            </generator>
        </id>

        <property name = "title" column = "title" type="string" not-null="true" />
        <property name = "productCondition" column = "product_condition" not-null="true">
            <type name="org.hibernate.type.EnumType">
                <param name="enumClass">com.marketplace.DiscProductManagement.Domain.Disc$ProductConditionEnum</param>
                <param name="useNamed">true</param>
            </type>
        </property>
<!--        <property name = "unitOfProduct" column = "unit_of_product" type = "string" not-null="true"/>-->
        <property name="unitOfProduct" column="unit_of_product" not-null="true">
            <type name="org.hibernate.type.EnumType">
                <param name="enumClass">com.marketplace.DiscProductManagement.Domain.Disc$UnitOfProductEnum</param>
                <param name="useNamed">true</param>
            </type>
        </property>

        <one-to-one name="product" class="com.marketplace.DiscProductManagement.Domain.Product" cascade="all" constrained="true" />
        <property name = "description" column = "description" type = "string" not-null="true"/>
        <property name = "publisher" column = "publisher" type = "string" not-null="true"/>

    </class>

    <class name="com.marketplace.DiscProductManagement.Domain.ProductVariant" table="`Product_Variants`">
        <meta attribute = "class-description">
            This class contains the certificate records.
        </meta>
        <id name = "id" type = "string" column = "id">
            <generator class="com.marketplace.Util.CustomGenerator"/>
        </id>
<!--        <set name = "productSubVariants" cascade="all">-->
<!--            <key column = "product_variant_id"/>-->
<!--            <one-to-many class="com.marketplace.DiscProductManagement.Domain.ProductSubVariant" />-->
<!--        </set>-->
        <property name = "name" column = "name" type = "string" not-null="true"/>


    </class>

<!--    <class name="com.marketplace.DiscProductManagement.Domain.ProductSubVariant" table="`Product_Sub_Variants`">-->
<!--        <meta attribute = "class-description">-->
<!--            This class contains the certificate records.-->
<!--        </meta>-->
<!--        <id name = "id" type = "string" column = "id">-->
<!--            <generator class="com.marketplace.Util.CustomGenerator"/>-->
<!--        </id>-->

<!--        <property name = "variantSpecificNameType" column = "variant_specific_name_type" type = "string" not-null="true"/>-->
<!--        <property name = "price" column = "price" type = "int" not-null="true" />-->

<!--    </class>-->

</hibernate-mapping>